URxvt.perl-ext-common:        default,url-select,xkr-clipboard,resize-font,selection-to-clipboard,pasta
URxvt.iso14755:               false
URxvt.keysym.Shift-Control-C: perl:clipboard:copy
URxvt.keysym.Control-Insert:  perl:clipboard:copy
URxvt.keysym.Control-Shift-V    : perl:pasta:paste
! Cursor theme
! Xcursor.theme: CG
Xcursor.theme: DMZ-White

! Colors - also see scripts/xcolor for switching
! #include "/home/alex/.xcolors/solarized.light.xcolors"

! Fonts
Xft.antialias:  true
Xft.hinting:    true
Xft.rgba:       rgb
Xft.hintstyle:  hintfull
Xft.dpi:        140

! urxvt.font:  xft:Source Code Pro:size=8
! urxvt.font:  xft:DejaVuSansMono:size=26
! urxvt.font:  xft:DejaVuSansMono:size=10
! urxvt.font:  xft:DejaVuSansMono:size=8
! urxvt.font:  xft:Terminus:size=8,xft:Inconsolata\ for\ Powerline:pixelsize=12
! urxvt.font:  xft:DejaVuSansMono\ for\ Powerline:size=8,xft:Inconsolata\ for\ Powerline:pixelsize=12
urxvt.font:  xft:DejaVu\ Sans\ Mono\ for\ Powerline:size=8,xft:Inconsolata\ for\ Powerline:pixelsize=16

URxvt.scrollBar:  false
URxvt.jumpScroll: true
URxvt.skipScroll: true
URxvt.saveLines:  1000
URxvt.visualBell: false

URxvt.depth:       24
URxvt.buffered:    false
!URxvt.foreground:  #f0f0f0
!URxvt.background:  #000000
URxvt.transparent: false
URxvt.shading:     100

URxvt.intensityStyles: true
URxvt.termName: rxvt-unicode-256color
URxvt.urgentOnBell: true

URxvt*cursorBlink: true


! Open url
URxvt.keysym.M-u: perl:url-select:select_next
URxvt.url-select.launcher: chromium
URxvt.url-select.underline: true

! need for contro + shift works
URxvt.iso14755_52: false

! resize font
URxvt.resize-font.smaller: C-minus
URxvt.resize-font.bigger: C-equal
